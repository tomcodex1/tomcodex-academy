# Keep every real API key only on the backend. Never expose keys in browser JavaScript.
AI_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=your_google_ai_studio_api_key_here
# Gemini also powers high-accuracy recorded interview transcription.
AI_SPEED_MODE=auto
PORT=3000
# Optional alternate learner record file, useful for isolated testing.
# STUDENT_STORE_PATH=data/learner-accounts.json

# ElevenLabs neural interviewer voice. Keep these values server-side.
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# Microsoft Azure Neural Voice. When configured, Azure is used before ElevenLabs.
AZURE_SPEECH_KEY=your_azure_speech_resource_key
AZURE_SPEECH_REGION=your_azure_resource_region
AZURE_SPEECH_VOICE=en-IN-PrabhatNeural
AZURE_SPEECH_LOCALE=en-IN

# Required for restricted tutor curriculum access.
TUTOR_EMAIL=tutor@example.com
TUTOR_ACCESS_CODE=replace-with-a-strong-private-code
